# Copy and edit this file for your cluster, then run:
#   bash examples/on_policy_distillation/sfcompute/prep-qwen3-8B-opd.sh
#   bash examples/on_policy_distillation/sfcompute/run-qwen3-8B-opd.sh

# Core paths
export ROOT_DIR="${ROOT_DIR:-$HOME}"
export POOL_DIR="${POOL_DIR:-$HOME/pool}"
export MEGATRON_PATH="${MEGATRON_PATH:-$HOME/Megatron-LM}"
export REPO_DIR="${REPO_DIR:-$HOME/slime}"

# 8x H100 defaults for Qwen3-32B teacher -> Qwen3-8B student:
#   GPU 6,7 -> teacher server (TP=2)
#   GPU 0-5 -> Ray + training
export TEACHER_VISIBLE_GPUS="${TEACHER_VISIBLE_GPUS:-6,7}"
export TEACHER_TP="${TEACHER_TP:-2}"
export RAY_VISIBLE_GPUS="${RAY_VISIBLE_GPUS:-0,1,2,3,4,5}"
export ACTOR_NUM_GPUS_PER_NODE="${ACTOR_NUM_GPUS_PER_NODE:-4}"
export ROLLOUT_NUM_GPUS="${ROLLOUT_NUM_GPUS:-1}"
export TENSOR_MODEL_PARALLEL_SIZE="${TENSOR_MODEL_PARALLEL_SIZE:-4}"

# Runtime knobs
export TEACHER_PORT="${TEACHER_PORT:-13141}"
export TEACHER_MEM_FRACTION="${TEACHER_MEM_FRACTION:-0.6}"
export SGLANG_MEM_FRACTION_STATIC="${SGLANG_MEM_FRACTION_STATIC:-0.4}"
export MAX_TEACHER_WAIT_SEC="${MAX_TEACHER_WAIT_SEC:-300}"
export ENABLE_EVAL="${ENABLE_EVAL:-0}"

# Optional tracking defaults for this setup
export WANDB_PROJECT="${WANDB_PROJECT:-slime-dev}"
export WANDB_GROUP="${WANDB_GROUP:-qwen3-32B-to-8B-opd}"
