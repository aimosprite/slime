# Optional config overrides for sfcompute scripts.
# Defaults are Docker-friendly for root containers and also work on native hosts.
# Copy/edit only if you need non-default paths or GPU layout.
#
# Run:
#   bash examples/on_policy_distillation/sfcompute/prep-opd.sh
#   bash examples/on_policy_distillation/sfcompute/run-opd.sh

# Core paths
# Docker default (root container) resolves to:
#   ROOT_DIR=/root, POOL_DIR=/root/pool, MEGATRON_PATH=/root/Megatron-LM
export ROOT_DIR="${ROOT_DIR:-$HOME}"
export POOL_DIR="${POOL_DIR:-$HOME/pool}"
export MEGATRON_PATH="${MEGATRON_PATH:-$HOME/Megatron-LM}"
# Optional: override repo root if not auto-detected from script location.
export REPO_DIR="${REPO_DIR:-$HOME/slime}"

# Single-node 8x H100 defaults:
#   - Student actor/rollout uses GPUs 0..3
#   - Teacher uses GPUs 4..7
export CLUSTER_NUM_NODES="${CLUSTER_NUM_NODES:-1}"
export GPUS_PER_NODE="${GPUS_PER_NODE:-8}"
export TEACHER_VISIBLE_GPUS="${TEACHER_VISIBLE_GPUS:-4,5,6,7}"
export TEACHER_TP="${TEACHER_TP:-4}"
export TEACHER_EP="${TEACHER_EP:-4}"
export RAY_VISIBLE_GPUS="${RAY_VISIBLE_GPUS:-0,1,2,3}"
export ACTOR_NUM_GPUS_PER_NODE="${ACTOR_NUM_GPUS_PER_NODE:-4}"
export ROLLOUT_NUM_GPUS_PER_ENGINE="${ROLLOUT_NUM_GPUS_PER_ENGINE:-4}"
export TENSOR_MODEL_PARALLEL_SIZE="${TENSOR_MODEL_PARALLEL_SIZE:-2}"

# Runtime knobs
export TEACHER_PORT="${TEACHER_PORT:-13141}"
export RAY_PORT="${RAY_PORT:-6379}"
export RAY_DASHBOARD_PORT="${RAY_DASHBOARD_PORT:-8265}"
export TEACHER_MEM_FRACTION="${TEACHER_MEM_FRACTION:-0.75}"
export SGLANG_MEM_FRACTION_STATIC="${SGLANG_MEM_FRACTION_STATIC:-0.6}"
export MAX_TEACHER_WAIT_SEC="${MAX_TEACHER_WAIT_SEC:-300}"
export ENABLE_EVAL="${ENABLE_EVAL:-0}"

# Optional tracking defaults for this setup
export WANDB_PROJECT="${WANDB_PROJECT:-slime-dev}"
export WANDB_GROUP="${WANDB_GROUP:-opd}"
